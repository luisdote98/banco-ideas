generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Idea {
  id          String  @id @default(cuid())
  title       String
  description String?
  nextStep    String?

  // type: IDEA | PROJECT
  type String @default("IDEA")

  scorePotential Int @default(5)
  scoreEffort    Int @default(5)
  scoreInterest  Int @default(5)

  category   Category? @relation(fields: [categoryId], references: [id])
  categoryId String?

  tags    TagsOnIdeas[]
  history IdeaHistory[]

  status String @default("DRAFT")

  // Imagen adjunta (URL de Vercel Blob)
  imageUrl String?

  // AI-ready fields (populated later)
  aiSummary       String?
  aiSuggestedTags String?   // JSON array string
  aiScore         Float?
  aiProcessedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ideas")
}

model IdeaHistory {
  id        String   @id @default(cuid())
  ideaId    String
  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  field     String
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())

  @@map("idea_history")
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  icon      String   @default("lightbulb")
  color     String   @default("#6366f1")
  ideas     Idea[]
  createdAt DateTime @default(now())

  @@map("categories")
}

model Tag {
  id    String        @id @default(cuid())
  name  String        @unique
  slug  String        @unique
  color String?
  ideas TagsOnIdeas[]

  @@map("tags")
}

model TagsOnIdeas {
  idea   Idea   @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  ideaId String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId  String

  @@id([ideaId, tagId])
  @@map("tags_on_ideas")
}
